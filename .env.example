# =============================================================================
# 环境变量配置文件示例
# =============================================================================
# 使用说明:
# 1. 复制此文件为 .env
# 2. 根据实际环境修改配置值
# 3. 不要将 .env 文件提交到版本控制
# =============================================================================

# -----------------------------------------------------------------------------
# 应用配置
# -----------------------------------------------------------------------------
# 运行环境 (development, test, production)
NODE_ENV=production

# 应用名称
APP_NAME=requirements-management-system

# 应用版本
APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------
# 后端 API 端口
API_PORT=8000

# 前端服务端口
WEB_PORT=3000

# 监听地址
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 日志格式 (json, text)
LOG_FORMAT=text

# 日志文件路径
LOG_FILE=/app/web/logs/app.log

# -----------------------------------------------------------------------------
# 存储配置
# -----------------------------------------------------------------------------
# 上传目录
UPLOAD_DIR=/app/uploads

# 输出目录
OUTPUT_DIR=/app/output

# 最大上传文件大小 (MB)
MAX_UPLOAD_SIZE=100

# -----------------------------------------------------------------------------
# 数据库配置 (如使用外部数据库)
# -----------------------------------------------------------------------------
# 数据库类型 (sqlite, postgresql, mysql)
DB_TYPE=sqlite

# 数据库路径 (SQLite)
DB_PATH=/app/web/data/database.db

# 数据库主机 (PostgreSQL/MySQL)
# DB_HOST=localhost

# 数据库端口
# DB_PORT=5432

# 数据库名称
# DB_NAME=rms

# 数据库用户
# DB_USER=rms

# 数据库密码
# DB_PASSWORD=your_password

# -----------------------------------------------------------------------------
# OCR 配置
# -----------------------------------------------------------------------------
# OCR 语言 (chi_sim: 简体中文，chi_tra: 繁体中文，eng: 英文)
OCR_LANGS=chi_sim+eng

# OCR 引擎 (tesseract, paddle)
OCR_ENGINE=tesseract

# OCR 线程数
OCR_THREADS=4

# -----------------------------------------------------------------------------
# 安全配置
# -----------------------------------------------------------------------------
# 启用安全头
SECURITY_HEADERS=1

# CORS 允许的源 (多个用逗号分隔)
CORS_ORIGINS=https://your-domain.com

# API 密钥 (用于认证)
# API_KEY=your_api_key_here

# JWT 密钥
# JWT_SECRET=your_jwt_secret_here

# JWT 过期时间 (小时)
JWT_EXPIRE_HOURS=24

# -----------------------------------------------------------------------------
# 性能配置
# -----------------------------------------------------------------------------
# 工作进程数
WORKERS=4

# 每个工作进程的连接数
WORKER_CONNECTIONS=1000

# 请求超时时间 (秒)
REQUEST_TIMEOUT=300

# -----------------------------------------------------------------------------
# 监控配置
# -----------------------------------------------------------------------------
# 启用健康检查
HEALTH_CHECK=1

# 健康检查间隔 (秒)
HEALTH_CHECK_INTERVAL=30

# 启用指标收集
METRICS_ENABLED=0

# 指标端点
# METRICS_ENDPOINT=http://prometheus:9090

# -----------------------------------------------------------------------------
# 邮件配置 (用于通知)
# -----------------------------------------------------------------------------
# SMTP 服务器
# SMTP_SERVER=smtp.example.com

# SMTP 端口
# SMTP_PORT=587

# SMTP 用户
# SMTP_USER=your_email@example.com

# SMTP 密码
# SMTP_PASSWORD=your_password

# 发件人邮箱
# SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# 其他配置
# -----------------------------------------------------------------------------
# 调试模式 (0: 关闭，1: 开启)
DEBUG=0

# 时区
TZ=Asia/Shanghai

# 字符集
CHARSET=utf-8
